<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>AESIT® — Compounding Intelligence™ Simulator | S³ Labs®</title>
<link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@400;600;700;800&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
:root {
  --carbon:       #000000;
  --titanium:     #888888;
  --brushed:      #A8A8A8;
  --chrome:       #C8C8C8;
  --grid-white:   #E8E8E8;
  --race-red:     #CC0000;
  --race-red-2:   #FF2020;
  --gold:         #D4AF37;

  --col-design:   #C48F1D;
  --col-ops:      #1C98A6;
  --col-protect:  #4070B8;

  --grad-chrome:     linear-gradient(135deg, #6A6A6A 0%, #D8D8D8 40%, #F0F0F0 55%, #A0A0A0 100%);
  --grad-chrome-bar: linear-gradient(135deg, #6A6A6A 0%, #888888 15%, #D8D8D8 32%, #F0F0F0 44%, #CACACA 56%, #909090 70%, #707070 83%, #A0A0A0 100%);
  --grad-steel:      linear-gradient(180deg, #232323 0%, #191919 50%, #202020 100%);
  --grad-red:        linear-gradient(135deg, #CC0000 0%, #FF2020 40%, #AA0000 100%);
  --grad-red-h:      linear-gradient(90deg, #CC0000 0%, #FF2020 50%, #991000 100%);
  --grad-gold:       linear-gradient(135deg, #B8922A 0%, #D4AF37 40%, #F0CC55 60%, #B8922A 100%);
  --grad-design:     linear-gradient(135deg, #8A6010 0%, #C48F1D 40%, #E0B040 60%, #A07015 100%);
  --grad-ops:        linear-gradient(135deg, #0E6070 0%, #1C98A6 40%, #30C0D0 60%, #0E7080 100%);
  --grad-protect:    linear-gradient(135deg, #244080 0%, #4070B8 40%, #6090D8 60%, #2A4890 100%);

  --border:         rgba(200,200,200,0.10);
  --border-mid:     rgba(200,200,200,0.20);
  --border-bright:  rgba(200,200,200,0.35);
  --text-secondary: #B0A898;
  --text-muted:     #888888;

  --title-font: 'League Spartan', sans-serif;
  --body-font:  'Barlow', sans-serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  min-height: 100vh;
  background: var(--carbon);
  color: var(--text-secondary);
  font-family: var(--body-font);
  line-height: 1.7;
  font-size: 15px;
  -webkit-font-smoothing: antialiased;
}

.container {
  width: 100%;
  max-width: 1100px;
  margin: 0 auto;
  padding: 52px 6%;
}

/* ══════════════════════════════════════
   HEADER
══════════════════════════════════════ */
.page-header {
  margin-bottom: 32px;
  padding-bottom: 24px;
  border-bottom: 1px solid var(--border-mid);
  position: relative;
}

.page-header::after {
  content: '';
  position: absolute;
  bottom: -1px; left: 0;
  width: 100px; height: 2px;
  background: var(--grad-red-h);
  border-radius: 1px;
}

.header-eyebrow {
  font-family: var(--title-font);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  background: var(--grad-chrome);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.header-eyebrow::after {
  content: '';
  display: inline-block;
  width: 32px; height: 1px;
  background: linear-gradient(90deg, rgba(200,200,200,0.4), transparent);
}

.header-title {
  font-family: var(--title-font);
  font-size: clamp(26px, 4vw, 42px);
  font-weight: 800;
  letter-spacing: -0.02em;
  line-height: 1.0;
  margin-bottom: 6px;
}

.title-main {
  background: var(--grad-chrome);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.title-accent {
  background: var(--grad-gold);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.header-subtitle {
  font-family: var(--title-font);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.06em;
  background: var(--grad-chrome);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  opacity: 0.65;
  margin-bottom: 14px;
}

.header-lead {
  font-size: 14px;
  font-weight: 300;
  line-height: 1.8;
  color: var(--text-secondary);
  max-width: 820px;
}

.header-lead strong {
  color: var(--chrome);
  font-weight: 500;
  -webkit-text-fill-color: var(--chrome);
}

/* ══════════════════════════════════════
   CONTROLS PANEL
══════════════════════════════════════ */
.controls-panel {
  margin-bottom: 28px;
  border: 1px solid var(--border-mid);
  border-radius: 10px;
  overflow: hidden;
  background: var(--grad-steel);
  box-shadow: 0 4px 24px rgba(0,0,0,0.55);
}

.controls-header {
  background: var(--grad-chrome-bar);
  padding: 12px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
}

.controls-header::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0;
  width: 80px; height: 2px;
  background: var(--grad-red-h);
}

.controls-header-title {
  font-family: var(--title-font);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #0A0A0A;
  text-shadow: 0 1px 2px rgba(255,255,255,0.5);
}

.controls-header-tag {
  font-family: var(--title-font);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  background: var(--grad-gold);
  color: #0A0A0A;
  padding: 3px 8px;
  border-radius: 3px;
}

.controls-body {
  padding: 24px 22px;
}

/* Metric cards row */
.metrics-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  margin-bottom: 24px;
}

@media (max-width: 600px) { .metrics-row { grid-template-columns: 1fr; } }

.metric-card {
  background: rgba(0,0,0,0.35);
  border: 1px solid var(--border-mid);
  border-radius: 8px;
  padding: 16px 18px;
  position: relative;
  overflow: hidden;
}

.metric-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
}

.metric-card.mc-design::before  { background: var(--grad-design); }
.metric-card.mc-ops::before     { background: var(--grad-ops); }
.metric-card.mc-total::before   { background: var(--grad-gold); }

.metric-label {
  font-family: var(--title-font);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--titanium);
  margin-bottom: 6px;
}

.metric-value {
  font-family: var(--title-font);
  font-size: 26px;
  font-weight: 800;
  line-height: 1;
  margin-bottom: 2px;
}

.mc-design .metric-value  { background: var(--grad-design);  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.mc-ops    .metric-value  { background: var(--grad-ops);     -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.mc-total  .metric-value  { background: var(--grad-gold);    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

.metric-sub {
  font-size: 11px;
  font-weight: 300;
  color: var(--text-muted);
}

/* Sliders */
.sliders-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px 28px;
}

@media (max-width: 640px) { .sliders-grid { grid-template-columns: 1fr; } }

.slider-row {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.slider-top {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.slider-name {
  font-family: var(--title-font);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--titanium);
}

.slider-val {
  font-family: var(--title-font);
  font-size: 13px;
  font-weight: 800;
}

.sv-design  { background: var(--grad-design);  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.sv-ops     { background: var(--grad-ops);     -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.sv-protect { background: var(--grad-protect); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.sv-years   { background: var(--grad-chrome);  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

input[type=range] {
  -webkit-appearance: none;
  width: 100%;
  height: 4px;
  border-radius: 2px;
  outline: none;
  cursor: pointer;
}

input[type=range].r-design  { background: linear-gradient(90deg, var(--col-design) var(--pct, 50%), rgba(255,255,255,0.08) var(--pct, 50%)); }
input[type=range].r-ops     { background: linear-gradient(90deg, var(--col-ops)    var(--pct, 50%), rgba(255,255,255,0.08) var(--pct, 50%)); }
input[type=range].r-protect { background: linear-gradient(90deg, var(--col-protect) var(--pct, 50%), rgba(255,255,255,0.08) var(--pct, 50%)); }
input[type=range].r-years   { background: linear-gradient(90deg, #A0A0A0 var(--pct, 50%), rgba(255,255,255,0.08) var(--pct, 50%)); }

input[type=range]::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 14px; height: 14px;
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,0.3);
  cursor: pointer;
}

input.r-design::-webkit-slider-thumb  { background: var(--col-design); }
input.r-ops::-webkit-slider-thumb     { background: var(--col-ops); }
input.r-protect::-webkit-slider-thumb { background: var(--col-protect); }
input.r-years::-webkit-slider-thumb   { background: #A8A8A8; }

/* Compounding mode toggles */
.mode-row {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  align-items: center;
  margin-top: 18px;
  padding-top: 18px;
  border-top: 1px solid var(--border);
}

.mode-label {
  font-family: var(--title-font);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--titanium);
  margin-right: 4px;
}

.mode-btn {
  font-family: var(--title-font);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 5px 14px;
  border-radius: 4px;
  cursor: pointer;
  transition: all 0.2s;
  border: 1px solid var(--border-mid);
  background: transparent;
  color: var(--titanium);
}

.mode-btn.active {
  background: rgba(212,175,55,0.15);
  border-color: rgba(212,175,55,0.4);
  color: var(--gold);
}

/* ══════════════════════════════════════
   CHART PANEL
══════════════════════════════════════ */
.chart-panel {
  margin-bottom: 28px;
  border: 1px solid var(--border-mid);
  border-radius: 10px;
  overflow: hidden;
  background: var(--grad-steel);
  box-shadow: 0 4px 20px rgba(0,0,0,0.5);
}

.chart-header {
  background: var(--grad-chrome-bar);
  padding: 12px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
}

.chart-header::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0;
  width: 80px; height: 2px;
  background: var(--grad-red-h);
}

.chart-header-title {
  font-family: var(--title-font);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #0A0A0A;
  text-shadow: 0 1px 2px rgba(255,255,255,0.5);
}

.legend-row {
  display: flex;
  gap: 18px;
  flex-wrap: wrap;
}

.leg-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: var(--title-font);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #0A0A0A;
}

.leg-dot {
  width: 10px; height: 10px;
  border-radius: 2px;
  flex-shrink: 0;
}

.chart-body {
  padding: 20px 22px 24px;
}

.chart-wrap {
  position: relative;
  width: 100%;
  height: 280px;
}

/* ══════════════════════════════════════
   DIVISION BREAKDOWN
══════════════════════════════════════ */
.section-label {
  font-family: var(--title-font);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  background: var(--grad-chrome);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.section-label::after {
  content: '';
  flex: 1; height: 1px;
  background: linear-gradient(90deg, var(--border-mid), transparent);
}

.division-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
  margin-bottom: 28px;
}

@media (max-width: 768px) { .division-grid { grid-template-columns: 1fr; } }

.division-col {
  border-radius: 10px;
  overflow: hidden;
  border: 1px solid var(--border-mid);
  background: var(--grad-steel);
  box-shadow: 0 4px 20px rgba(0,0,0,0.5);
  display: flex;
  flex-direction: column;
}

.division-col.d-design  { border-top: 3px solid var(--col-design); }
.division-col.d-ops     { border-top: 3px solid var(--col-ops); }
.division-col.d-protect { border-top: 3px solid var(--col-protect); }

.col-header {
  background: var(--grad-chrome-bar);
  padding: 14px 16px;
}

.col-division-badge {
  font-family: var(--title-font);
  font-size: 8px;
  font-weight: 800;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  padding: 3px 8px;
  border-radius: 3px;
  margin-bottom: 6px;
  display: inline-block;
}

.d-design  .col-division-badge { background: rgba(196,143,29,0.2);  color: var(--col-design);  border: 1px solid rgba(196,143,29,0.4); }
.d-ops     .col-division-badge { background: rgba(28,152,166,0.15); color: var(--col-ops);     border: 1px solid rgba(28,152,166,0.35); }
.d-protect .col-division-badge { background: rgba(64,112,184,0.15); color: var(--col-protect); border: 1px solid rgba(64,112,184,0.35); }

.col-title {
  font-family: var(--title-font);
  font-size: 15px;
  font-weight: 800;
  letter-spacing: -0.01em;
  color: #0A0A0A;
  text-shadow: 0 1px 2px rgba(255,255,255,0.55);
  line-height: 1.1;
  margin-bottom: 2px;
}

.col-tagline {
  font-family: var(--title-font);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #444;
}

.col-rate-bar {
  padding: 12px 16px;
  background: rgba(0,0,0,0.25);
  border-bottom: 1px solid var(--border);
}

.rate-bar-label {
  font-family: var(--title-font);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--titanium);
  margin-bottom: 6px;
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.rate-pct {
  font-size: 13px;
  font-weight: 800;
}

.d-design  .rate-pct { color: var(--col-design);  -webkit-text-fill-color: var(--col-design); }
.d-ops     .rate-pct { color: var(--col-ops);     -webkit-text-fill-color: var(--col-ops); }
.d-protect .rate-pct { color: var(--col-protect); -webkit-text-fill-color: var(--col-protect); }

.bar-track {
  height: 6px;
  background: rgba(255,255,255,0.06);
  border-radius: 3px;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 3px;
  transition: width 0.6s ease;
}

.d-design  .bar-fill { background: var(--grad-design); }
.d-ops     .bar-fill { background: var(--grad-ops); }
.d-protect .bar-fill { background: var(--grad-protect); }

.col-body {
  padding: 16px;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.intel-contrib {
  padding: 11px 13px;
  border-radius: 6px;
  border: 1px solid;
}

.d-design  .intel-contrib { background: rgba(196,143,29,0.06); border-color: rgba(196,143,29,0.2); }
.d-ops     .intel-contrib { background: rgba(28,152,166,0.06); border-color: rgba(28,152,166,0.18); }
.d-protect .intel-contrib { background: rgba(64,112,184,0.06); border-color: rgba(64,112,184,0.18); }

.contrib-term {
  font-family: var(--title-font);
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  margin-bottom: 4px;
}

.d-design  .contrib-term { background: var(--grad-design);  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.d-ops     .contrib-term { background: var(--grad-ops);     -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.d-protect .contrib-term { background: var(--grad-protect); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

.contrib-desc {
  font-size: 12px;
  font-weight: 300;
  color: var(--text-muted);
  line-height: 1.55;
}

.intel-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 7px;
}

.intel-list li {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 8px;
  padding-bottom: 7px;
  border-bottom: 1px solid var(--border);
  font-size: 12px;
}

.intel-list li:last-child { border-bottom: none; padding-bottom: 0; }

.intel-name {
  color: var(--text-muted);
  font-weight: 300;
  flex: 1;
  line-height: 1.4;
}

.intel-fig {
  font-family: var(--title-font);
  font-size: 12px;
  font-weight: 800;
  white-space: nowrap;
  flex-shrink: 0;
}

.d-design  .intel-fig { color: var(--col-design);  -webkit-text-fill-color: var(--col-design); }
.d-ops     .intel-fig { color: var(--col-ops);     -webkit-text-fill-color: var(--col-ops); }
.d-protect .intel-fig { color: var(--col-protect); -webkit-text-fill-color: var(--col-protect); }

.sys-row { display: flex; gap: 5px; flex-wrap: wrap; }

.sys-pill {
  font-family: var(--title-font);
  font-size: 8px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 3px 8px;
  border-radius: 3px;
  border: 1px solid;
}

.d-design  .sys-pill { background: rgba(196,143,29,0.1); color: var(--col-design);  border-color: rgba(196,143,29,0.25); }
.d-ops     .sys-pill { background: rgba(28,152,166,0.1); color: var(--col-ops);     border-color: rgba(28,152,166,0.22); }
.d-protect .sys-pill { background: rgba(64,112,184,0.1); color: var(--col-protect); border-color: rgba(64,112,184,0.22); }

/* ══════════════════════════════════════
   RULE OF 72 CALLOUT
══════════════════════════════════════ */
.rule72-panel {
  display: flex;
  align-items: baseline;
  gap: 14px;
  flex-wrap: wrap;
  padding: 16px 20px;
  background: linear-gradient(135deg, rgba(192,192,192,0.07) 0%, rgba(168,168,168,0.03) 50%, rgba(192,192,192,0.06) 100%);
  border: 1px solid var(--border-mid);
  border-left: 3px solid var(--gold);
  border-radius: 0 8px 8px 0;
  margin-bottom: 28px;
}

.rule72-label {
  font-family: var(--title-font);
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  background: var(--grad-gold);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  flex-shrink: 0;
  white-space: nowrap;
}

.rule72-text {
  font-size: 13px;
  font-weight: 300;
  color: var(--text-muted);
  line-height: 1.6;
}

.rule72-text strong {
  color: var(--brushed);
  font-weight: 500;
  -webkit-text-fill-color: var(--brushed);
}

/* ══════════════════════════════════════
   STACKED PHASE BAR
══════════════════════════════════════ */
.phase-panel {
  border: 1px solid var(--border-mid);
  border-radius: 10px;
  overflow: hidden;
  background: var(--grad-steel);
  box-shadow: 0 4px 20px rgba(0,0,0,0.5);
  margin-bottom: 28px;
}

.phase-header {
  background: var(--grad-chrome-bar);
  padding: 11px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
}

.phase-header::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0;
  width: 80px; height: 2px;
  background: var(--grad-red-h);
}

.phase-header-title {
