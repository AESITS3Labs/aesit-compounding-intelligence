<script>
let freq = 1;
let chart;

function setFreq(f, btn) {
  freq = f;
  document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  update();
}

function updateSliderFill(el, min, max) {
  const pct = ((+el.value - min) / (max - min) * 100).toFixed(1) + '%';
  el.style.setProperty('--pct', pct);
}

function compound(rate, years, n) {
  return Math.pow(1 + rate / n, n * years);
}

function update() {
  const dRate   = +document.getElementById('sl-design').value / 100;
  const oRate   = +document.getElementById('sl-ops').value / 100;
  const pRate   = +document.getElementById('sl-protect').value / 100;
  const years   = +document.getElementById('sl-years').value;

  document.getElementById('out-design').textContent  = Math.round(dRate*100) + '% / yr';
  document.getElementById('out-ops').textContent     = Math.round(oRate*100) + '% / yr';
  document.getElementById('out-protect').textContent = Math.round(pRate*100) + '% / yr';
  document.getElementById('out-years').textContent   = years + ' yrs';

  updateSliderFill(document.getElementById('sl-design'),  1, 30);
  updateSliderFill(document.getElementById('sl-ops'),     1, 30);
  updateSliderFill(document.getElementById('sl-protect'), 1, 30);
  updateSliderFill(document.getElementById('sl-years'),   1, 50);

  const maxRate = Math.max(dRate, oRate, pRate);
  const combinedRate = dRate + oRate + pRate;

  const dFinal = compound(dRate, years, freq);
  const oFinal = compound(oRate, years, freq);
  const pFinal = compound(pRate, years, freq);
  const cFinal = compound(combinedRate, years, freq);

  document.getElementById('val-multiplier').textContent = cFinal.toFixed(1) + '×';
  document.getElementById('val-gained').textContent     = (cFinal - 1).toFixed(1) + '×';
  const doubling = (72 / (combinedRate * 100));
  document.getElementById('val-double').textContent     = doubling.toFixed(1) + ' yrs';

  document.getElementById('bar-design-pct').textContent  = Math.round(dRate*100) + '% / yr';
  document.getElementById('bar-ops-pct').textContent     = Math.round(oRate*100) + '% / yr';
  document.getElementById('bar-protect-pct').textContent = Math.round(pRate*100) + '% / yr';

  document.getElementById('bar-design').style.width  = Math.min(100, Math.round(dRate*100/30*100)) + '%';
  document.getElementById('bar-ops').style.width     = Math.min(100, Math.round(oRate*100/30*100)) + '%';
  document.getElementById('bar-protect').style.width = Math.min(100, Math.round(pRate*100/30*100)) + '%';

  const totalRate = Math.round(combinedRate * 100);
  const doubYrs   = doubling.toFixed(1);
  document.getElementById('rule72-text').innerHTML =
    'At a combined rate of <strong>' + totalRate + '%/yr</strong>, your asset\'s intelligence base doubles in roughly <strong>' + doubYrs + ' years</strong>. Every compounding period that passes without AESIT intelligence active is a doubling left on the table. ∞';

  const labels = [];
  const dData = [], oData = [], pData = [], cData = [], linData = [];

  for (let y = 0; y <= years; y++) {
    labels.push(y === 0 ? 'Now' : 'Yr ' + y);
    dData.push(+compound(dRate, y, freq).toFixed(3));
    oData.push(+compound(oRate, y, freq).toFixed(3));
    pData.push(+compound(pRate, y, freq).toFixed(3));
    cData.push(+compound(combinedRate, y, freq).toFixed(3));
    linData.push(+(1 + combinedRate * y).toFixed(3));
  }

  if (chart) chart.destroy();
  chart = new Chart(document.getElementById('intel-chart'), {
    type: 'line',
    data: {
      labels,
      datasets: [
        {
          label: 'Combined',
          data: cData,
          borderColor: '#D4AF37',
          backgroundColor: 'rgba(212,175,55,0.08)',
          fill: true,
          tension: 0.4,
          pointRadius: 0,
          borderWidth: 2.5
        },
        {
          label: 'Operations',
          data: oData,
          borderColor: '#1C98A6',
          backgroundColor: 'transparent',
          fill: false,
          tension: 0.4,
          pointRadius: 0,
          borderWidth: 1.5
        },
        {
          label: 'Design',
          data: dData,
          borderColor: '#C48F1D',
          backgroundColor: 'transparent',
          fill: false,
          tension: 0.4,
          pointRadius: 0,
          borderWidth: 1.5
        },
        {
          label: 'Protection',
          data: pData,
          borderColor: '#4070B8',
          backgroundColor: 'transparent',
          fill: false,
          tension: 0.4,
          pointRadius: 0,
          borderWidth: 1.5
        },
        {
          label: 'Linear Baseline',
          data: linData,
          borderColor: 'rgba(200,200,200,0.25)',
          backgroundColor: 'transparent',
          fill: false,
          tension: 0,
          pointRadius: 0,
          borderWidth: 1,
          borderDash: [5, 4]
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: ctx => ctx.dataset.label + ': ' + ctx.raw.toFixed(2) + '×'
          }
        }
      },
      scales: {
        x: {
          ticks: { color: '#666', font: { size: 11 }, autoSkip: true, maxTicksLimit: 11 },
          grid: { display: false }
        },
        y: {
          ticks: {
            color: '#666',
            font: { size: 11 },
            callback: v => v.toFixed(1) + '×'
          },
          grid: { color: 'rgba(255,255,255,0.04)' }
        }
      }
    }
  });
}

['sl-design','sl-ops','sl-protect','sl-years'].forEach(id => {
  document.getElementById(id).addEventListener('input', update);
});

update();
</script>
</body>
</html>
